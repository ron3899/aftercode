# SQLite by default — a single file, created + migrated automatically on startup.
# No database server to run. (Postgres is no longer used.)
DATABASE_URL=sqlite://aftercode.db?mode=rwc
# Loopback only. Aftercode's local-approval login has NO identity check, so do
# NOT bind to 0.0.0.0 / expose this publicly without putting real auth in front.
BIND_ADDR=127.0.0.1:8080
APP_PUBLIC_URL=http://localhost:8080
WEB_DIST=web/dist
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
TTS_PROVIDER=elevenlabs
ELEVENLABS_API_KEY=
ELEVENLABS_HOST_VOICE_ID=
ELEVENLABS_EXPERT_VOICE_ID=
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE_HOST=alloy
OPENAI_TTS_VOICE_EXPERT=onyx
BLOB_STORE=localfs
LOCALFS_DIR=./data/audio
S3_BUCKET=
